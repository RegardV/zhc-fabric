# Copy to:  $HERMES_HOME/zhc-fabric/sidecar.env
#   default: ~/.hermes/zhc-fabric/sidecar.env
# Then:     chmod 600 that file
# Start:    scripts/install-sidecar.sh start   # Docker OTP (no host Erlang)
#
# Optional: same ZHC_FABRIC_DEFAULT_* keys may live in ~/.hermes/.env
#           (see: hermes config env-path)

# Required — OpenAI-compatible base URL ending in /v1
# For models on the same machine as Docker, 127.0.0.1 is fine in this file;
# install-sidecar.sh rewrites it to host.docker.internal for the container.
ZHC_FABRIC_DEFAULT_BASE_URL=http://127.0.0.1:11434/v1
DEFAULT_BASE_URL=http://127.0.0.1:11434/v1

# Required — model id your server expects
ZHC_FABRIC_DEFAULT_MODEL=llama3.2
DEFAULT_MODEL=llama3.2

# Optional — leave empty for most local servers
ZHC_FABRIC_DEFAULT_API_KEY=
DEFAULT_API_KEY=

# Optional — global concurrent outbound LLM calls
MAX_INFLIGHT_COMPLETIONS=2
